{
  "headers": [
    {
      "source": "/(assets|images)/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).(js|css|webp|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|otf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/:path*", "destination": "/blog/index.html" },
    { "source": "/menu", "destination": "/menu/index.html" },
    { "source": "/menu/:path*", "destination": "/menu/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
